# Intuit app credentials — create an app at https://developer.intuit.com (Accounting scope).
# Use the Development keys with QBO_ENVIRONMENT=sandbox, Production keys with =production.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=

# Must exactly match a redirect URI registered on the Intuit app.
# In dev this goes through the Vite proxy so the browser stays on the Vite origin.
QBO_REDIRECT_URI=http://localhost:5173/api/auth/callback

# sandbox | production
QBO_ENVIRONMENT=sandbox

PORT=3001

# Hosting (optional): DATA_DIR relocates the SQLite database (Render disk).
# DATA_DIR=/var/data
